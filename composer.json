{
    "name": "dansup/klipy-php",
    "description": "PHP / Laravel client for the Klipy API (GIFs, Stickers, Clips, Memes, AI Emojis).",
    "type": "library",
    "license": "MIT",
    "keywords": ["klipy", "gif", "stickers", "memes", "clips", "laravel", "php"],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Klipy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Klipy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Klipy\\Laravel\\KlipyServiceProvider"
            ],
            "aliases": {
                "Klipy": "Klipy\\Laravel\\Facades\\Klipy"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
